{
  "name": "overseer-tui",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --outfile=dist/overseer.mjs --external:better-sqlite3 --loader:.js=jsx --loader:.jsx=jsx --jsx=automatic --jsx-import-source=react --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "npm run build && node dist/overseer.mjs"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "chalk": "^5.3.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
