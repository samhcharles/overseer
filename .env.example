# Overseer environment variables
# Copy to .env and fill in your values.
# setup.sh writes .env automatically for local installs.

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_PATH=~/vault
USER_TIMEZONE=America/Los_Angeles

# ── Ollama (local inference) ──────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=dolphin3:latest

# ── Alternative providers (set OVERSEER_BACKEND to use) ──────────────────────
# OVERSEER_BACKEND=auto        # auto | ollama | gemini | groq | openrouter
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── API node ──────────────────────────────────────────────────────────────────
OVERSEER_API_KEY=                    # auth key for inbound requests (optional locally)
OVERSEER_STATE_DIR=~/.local/state/overseer
OVERSEER_BIND_HOST=127.0.0.1        # set to 0.0.0.0 for Docker

# ── TUI ───────────────────────────────────────────────────────────────────────
OVERSEER_API_URL=http://localhost:8765

# ── VPS gateway (optional) ────────────────────────────────────────────────────
# NODE_SECRET=                       # shared secret between local node and gateway
# WORKER_URL=                        # gateway URL
# WORKER_SECRET=                     # gateway auth token

# ── Urchin integration (optional) ────────────────────────────────────────────
# SLEIPNIR_DB=~/.local/share/urchin/sleipnir.db
# URCHIN_JOURNAL=~/.local/share/urchin/journal/events.jsonl

# ── Git vault sync (Docker only) ─────────────────────────────────────────────
# GIT_USER=your-github-username
# GIT_TOKEN=your-github-pat
