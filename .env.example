# Overseer — example environment file
# Copy to .env (or ~/.secrets/overseer.env) and fill in.
# All values shown are defaults; uncomment only the ones you need to change.

# ─── Vault ───────────────────────────────────────────────────────────────────
# Path to your Obsidian vault (the "brain" Overseer reads and writes to).
# Run ./setup.sh once to scaffold a fresh vault here.
VAULT_PATH=/home/you/vault

# ─── Local model (Ollama) — default backend ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=dolphin3:latest
OLLAMA_CTX=4096

# ─── Timezone (controls date stamps in vault writes) ─────────────────────────
USER_TIMEZONE=America/Los_Angeles

# ─── Overseer node ───────────────────────────────────────────────────────────
NODE_PORT=7860
OVERSEER_STATE_DIR=/home/you/.local/state/overseer

# ─── Optional: cloud provider fallback ───────────────────────────────────────
# Overseer prefers local Ollama. These are only used if explicitly selected
# via OVERSEER_BACKEND or via the gateway routing.
OVERSEER_BACKEND=auto    # auto | ollama | gemini | groq | openrouter

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ─── Optional: gateway (always-on VPS router) ────────────────────────────────
# Leave blank for standalone single-node use.
GATEWAY_URL=
NODE_INFERENCE_URL=
NODE_SECRET=

# Worker URL + secret (used when running behind a Cloudflare Worker edge)
WORKER_URL=
WORKER_SECRET=
OVERSEER_API_KEY=

# ─── Urchin + Sleipnir paths (optional) ──────────────────────────────────────
# Overseer reads recent activity context from Urchin's journal and Sleipnir's
# distilled clusters if available. Both are Orinadus products and are NOT
# required to run Overseer.
URCHIN_JOURNAL=/home/you/.local/share/urchin/journal/events.jsonl
SLEIPNIR_DB=/home/you/.local/share/urchin/sleipnir.db
